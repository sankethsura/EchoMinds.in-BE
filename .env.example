LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
OPENAI_API_KEY=your_openai_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
# Optional — required only for the Phone Call (outbound) feature
# Get from LiveKit Cloud → SIP → Outbound Trunks
LIVEKIT_SIP_TRUNK_ID=

# Optional — required only for the Inbound Call feature
# Get from LiveKit Cloud → SIP → Inbound Trunks
LIVEKIT_SIP_INBOUND_TRUNK_ID=
# The DID phone number associated with the inbound trunk (E.164, e.g. +15551234567)
LIVEKIT_INBOUND_PHONE_NUMBER=
